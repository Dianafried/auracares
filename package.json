{
  "name": "kedicare",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "npm run sass && npm run copy-static",
    "vercel": "vercel --prod",
    "sass": "sass --no-source-map src/scss:public/css",
    "copy-static": "copyfiles -u 1 \"**/*.{html,js,css,png,jpg,svg}\" public/"
  },
  "devDependencies": {
    "sass": "^1.77.2",
    "copyfiles": "^2.4.1"
  }
}
